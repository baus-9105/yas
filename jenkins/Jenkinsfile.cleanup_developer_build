// ============================================================
// Job: developer_teardown_env
// Mục đích: Xóa toàn bộ Helm releases và Namespace của Developer
// ============================================================

pipeline {
    agent any

    parameters {
        string(name: 'DEVELOPER_NAMESPACE', defaultValue: 'dev', description: 'Tên K8s namespace muốn xóa')
        booleanParam(name: 'CONFIRM_DESTROY', defaultValue: false, description: 'VUI LÒNG TÍCH VÀO ĐÂY ĐỂ XÁC NHẬN XÓA')
    }

    environment {
        KUBECONFIG = credentials('kubeconfig')
    }

    stages {
        stage('Safety Check') {
            steps {
                script {
                    if (!params.CONFIRM_DESTROY) {
                        error("Hủy bỏ tiến trình: Bạn chưa tích chọn ô CONFIRM_DESTROY.")
                    }
                    def protectedNamespaces = ['default', 'kube-system', 'kube-public', 'jenkins', 'stakater']
                    if (protectedNamespaces.contains(params.DEVELOPER_NAMESPACE)) {
                        error("BẢO MẬT: Tuyệt đối không được phép xóa namespace hệ thống '${params.DEVELOPER_NAMESPACE}'!")
                    }
                }
            }
        }

        stage('Prepare Tools (Helm & Kubectl)') {
            steps {
                script {
                    echo "Đang cài đặt công cụ (Helm, Kubectl) cho Agent..."
                    sh """
                        mkdir -p "\${WORKSPACE}/bin"
                        export PATH="\${WORKSPACE}/bin:\$PATH"

                        # Tải Helm
                        if ! command -v helm &> /dev/null; then
                            curl -fsSL -o get_helm.sh https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3
                            chmod 700 get_helm.sh
                            USE_SUDO="false" HELM_INSTALL_DIR="\${WORKSPACE}/bin" DESIRED_VERSION="v3.15.4" ./get_helm.sh
                        fi

                        # Tải Kubectl
                        if ! command -v kubectl &> /dev/null; then
                            curl -fsSL -o "\${WORKSPACE}/bin/kubectl" "https://dl.k8s.io/release/\$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
                            chmod +x "\${WORKSPACE}/bin/kubectl"
                        fi
                    """
                }
            }
        }

        stage('Uninstall Helm Releases') {
            steps {
                script {
                    echo "Đang quét các service (Helm releases) trong namespace: ${params.DEVELOPER_NAMESPACE}..."
                    
                    def releases = sh(
                        script: """
                            export PATH="\${WORKSPACE}/bin:\$PATH"
                            helm ls -q -n ${params.DEVELOPER_NAMESPACE} 2>/dev/null || true
                        """,
                        returnStdout: true
                    ).trim()

                    if (releases == '') {
                        echo "Không tìm thấy service nào đang chạy trong namespace ${params.DEVELOPER_NAMESPACE}."
                    } else {
                        def releaseList = releases.split('\n')
                        releaseList.each { release ->
                            echo "Đang xóa service: ${release}..."
                            sh """
                                export PATH="\${WORKSPACE}/bin:\$PATH"
                                helm uninstall ${release} -n ${params.DEVELOPER_NAMESPACE} --wait --timeout 120s || true
                            """
                        }
                    }
                }
            }
        }

        stage('Delete K8s Namespace') {
            steps {
                script {
                    echo "Đang dọn dẹp hoàn toàn namespace '${params.DEVELOPER_NAMESPACE}'..."
                    sh """
                        export PATH="\${WORKSPACE}/bin:\$PATH"
                        kubectl delete namespace ${params.DEVELOPER_NAMESPACE} --ignore-not-found=true --timeout=150s
                    """
                }
            }
        }
    }

    post {
        success {
            echo """
========================================================================
DỌN DẸP HOÀN TẤT!
Toàn bộ service và namespace '${params.DEVELOPER_NAMESPACE}' đã được xóa.
========================================================================
            """
        }
        failure {
            echo "Quá trình dọn dẹp gặp lỗi. Vui lòng kiểm tra log."
        }
    }
}